# Narration provider: macos-say or voicebox
TTS_PROVIDER=macos-say

# macOS built-in narration
MACOS_SAY_VOICE=Daniel

# Voicebox / Chatterbox narration
VOICEBOX_API_BASE=http://127.0.0.1:8000
VOICEBOX_ENGINE=chatterbox_turbo
VOICEBOX_PROFILE_NAME=Technical Narrator
VOICEBOX_PROFILE_DESIGN_PROMPT=Clear, warm technical narrator with calm documentary pacing.
VOICEBOX_GENERATION_INSTRUCT=Speak clearly and naturally. Keep sentence endings confident and unhurried.
# Set this to reuse an existing Voicebox profile instead of creating one.
# VOICEBOX_PROFILE_ID=
